  "diagnostic-languageserver.mergeConfig": true,
  "diagnostic-languageserver.linters": {
    "phpcs": {
      "command": "docker",
      "debounce": 100,
      "rootPatterns": [
        "composer.json",
        "composer.lock",
        "vendor",
        ".git"
      ],
      "args": [
        "exec",
        "-u",
        "docker",
        "-w",
        "/var/www/sp2-php",
        "sp2-php_app_1",
        "/var/www/sp2-php/vendor/bin/phpcs",
        "--report=emacs",
        "%relativepath"
      ],
      "offsetLine": 0,
      "offsetColumn": 0,
      "sourceName": "phpcs",
      "formatLines": 1,
      "formatPattern": [
        "^.*:(\\d+):(\\d+):\\s+(.*)\\s+-\\s+(.*)(\\r|\\n)*$",
        {
          "line": 1,
          "column": 2,
          "message": 4,
          "security": 3
        }
      ],
      "securities": {
        "error": "error",
        "warning": "warning"
      }
    },
    "phpstan": {
      "command": "docker",
      "debounce": 100,
      "rootPatterns": [
        "composer.json",
        "composer.lock",
        "vendor",
        ".git"
      ],
      "args": [
        "exec",
        "-u",
        "docker",
        "-w",
        "/var/www/sp2-php",
        "sp2-php_app_1",
        "/var/www/sp2-php/vendor/bin/phpstan",
        "analyse",
        "--configuration=/var/www/sp2-php/phpstan.neon",
        "--error-format",
        "raw",
        "--no-progress",
        "%relativepath"
      ],
      "offsetLine": 0,
      "offsetColumn": 0,
      "sourceName": "phpstan",
      "formatLines": 1,
      "formatPattern": [
        "^[^:]+:(\\d+):(.*)(\\r|\\n)*$",
        {
          "line": 1,
          "message": 2
        }
      ]
    }
  },
  "diagnostic-languageserver.filetypes": {
    "vim": "vint",
    "sh": "shellcheck",
    "javascript": "eslint",
    "php": [
      "phpcs",
      "phpstan"
    ]
  },
  "languageserver": {
    "qls": {
      "command": "/home/kf/go/bin/sqls",
