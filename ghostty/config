font-family = "RuikaMono07 Nerd Font"
font-size = 24
theme = "Solarized Dark Patched"

# クイックターミナルの位置を画面上部に設定
quick-terminal-position = "top"

# クイックターミナルを表示するスクリーンを設定 (メインスクリーン)
quick-terminal-screen = "main"

# アニメーション時間を設定（0で即時表示）
quick-terminal-animation-duration = 0

# リガチャ不要
font-feature = -calt
font-feature = -dlig

# マウス設定
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# カーソル設定
cursor-opacity = 0.7
cursor-style = block
cursor-style-blink = false
cursor-color = #ff0000

unfocused-split-opacity = 0.825

fullscreen = false

window-inherit-working-directory = true

resize-overlay = never
keybind = shift+enter=text:\x1b\r
# Why: unbind/ignore ではなく text:\x1bf を採用。Cmd は端末プロトコルに修飾キーとして存在せず
#      unbind では tmux に何も届かない（無反応になる）。そこで ESC+f(=\x1b f, tmux の M-f) を
#      明示送出し、tmux root テーブルの M-f バインド(fuzzy-motion 起動)を発火させる。
keybind = cmd+f=text:\x1bf

# Macの場合タイトルバーを隠す
macos-titlebar-style = hidden